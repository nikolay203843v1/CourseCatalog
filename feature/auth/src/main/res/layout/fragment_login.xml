<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cc_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".LoginFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minHeight="720dp"
        android:paddingStart="@dimen/cc_screen_padding"
        android:paddingEnd="@dimen/cc_screen_padding">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="142dp"
            android:text="@string/login_title"
            android:textColor="@color/cc_on_background"
            android:textSize="28sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/email_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/email_label"
            android:textColor="@color/cc_on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />

        <EditText
            android:id="@+id/email_input"
            android:layout_width="0dp"
            android:layout_height="@dimen/cc_control_height"
            android:layout_marginTop="8dp"
            android:autofillHints="emailAddress"
            android:background="@drawable/bg_rounded_control"
            android:hint="@string/email_hint"
            android:importantForAutofill="yes"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:paddingHorizontal="20dp"
            android:textColor="@color/cc_on_surface"
            android:textColorHint="@color/cc_on_surface_variant"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/email_label" />

        <TextView
            android:id="@+id/password_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/password_label"
            android:textColor="@color/cc_on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/email_input" />

        <EditText
            android:id="@+id/password_input"
            android:layout_width="0dp"
            android:layout_height="@dimen/cc_control_height"
            android:layout_marginTop="8dp"
            android:autofillHints="password"
            android:background="@drawable/bg_rounded_control"
            android:hint="@string/password_hint"
            android:importantForAutofill="yes"
            android:inputType="textPassword"
            android:maxLines="1"
            android:paddingHorizontal="20dp"
            android:textColor="@color/cc_on_surface"
            android:textColorHint="@color/cc_on_surface_variant"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/password_label" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/login_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/cc_control_height"
            android:layout_marginTop="24dp"
            android:enabled="false"
            android:text="@string/login_action"
            android:textAllCaps="false"
            android:textColor="@color/cc_on_background"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/login_button_background"
            app:cornerRadius="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/password_input" />

        <LinearLayout
            android:id="@+id/registration_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_button">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_account"
                android:textColor="@color/cc_on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/registration_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/registration"
                android:textColor="@color/cc_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/forgot_password_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/forgot_password"
            android:textColor="@color/cc_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/registration_row" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="38dp"
            android:background="@color/cc_outline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/forgot_password_button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/vk_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/cc_control_height"
            android:layout_marginTop="38dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/open_vk"
            android:text="VK"
            android:textAllCaps="false"
            android:textColor="@color/cc_on_background"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/cc_blue"
            app:cornerRadius="28dp"
            app:layout_constraintEnd_toStartOf="@id/ok_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ok_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/cc_control_height"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/open_ok"
            android:text="OK"
            android:textAllCaps="false"
            android:textColor="@color/cc_on_background"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/cc_orange"
            app:cornerRadius="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vk_button"
            app:layout_constraintTop_toTopOf="@id/vk_button" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
